<!-- Developers - Add -->
<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head") %>
  <body>
    <%- include("../partials/header") %>
    <main>
      <form
        class="add-and-edit-form add-and-edit-developer"
        action="/developers/add"
        method="POST"
      >
        <div class="title-container">
          <label for="developer">Add Developer</label>
          <input type="text" name="developer" id="developer" required />
        </div>
        <div class="image-link-container">
          <label for="developer-image">Developer Image Link</label>
          <input type="url" name="developerImgUrl" id="developer-image" />
        </div>
        <div class="view-button-container">
          <a href="/developers/">Back</a>
          <button type="text">Submit</button>
        </div>
      </form>
    </main>
    <%- include("../partials/footer") %>
  </body>
</html>
