<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head") %>
  <body>
    <%- include("../partials/header") %>
    <main>
      <form
        class="add-and-edit-form"
        action="/developers/edit/<%= developer.id %>"
        method="POST"
      >
        <div class="dev-title-container">
          <label for="<%= developer.id %>">Edit Developer</label>
          <input
            type="text"
            name="developer"
            id="<%= developer.id %>"
            value="<%= developer.developer%>"
            required
          />
        </div>
        <div class="image-link-container">
          <label for="developer-image">Developer Image Link</label>
          <input
            type="url"
            name="developerImgUrl"
            id="developer-image"
            value="<%= developer.img_url  %>"
          />
        </div>
        <button type="text">Submit</button>
      </form>
    </main>
    <%- include("../partials/footer") %>
  </body>
</html>
