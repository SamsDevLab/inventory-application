<!-- Games - New -->
<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head") %>
  <body>
    <%- include("../partials/header") %>
    <main>
      <form class="game-form" action="/games/add" method="POST">
        <div class="game-title-container">
          <label for="game">Game Title</label>
          <input type="text" name="game" id="game" required />
        </div>
        <div class="image-container">
          <label for="game-image">Game Image Link</label>
          <input type="url" name="gameImgUrl" id="game-image">
        </div>
        <h3>Developer (select as many as needed)</h3>
        <div class="selection-container">
        <% developerRows.forEach(row => { %>
          <div>
            <input type="checkbox" id="<%= row.id %>" value="<%= row.id %>" name="developers[]" />
            <label for="<%= row.id %>"><%= row.developer %></label>
          </div>
         <% }) %>
        </div>
        <h3>Genre (select as many as needed)</h3>
        <div class="selection-container">
         <% genreRows.forEach(row => { %>
          <div>
            <input type="checkbox" id="<%= row.id %>" value="<%= row.id %>" name="genres[]" />
            <label for="<%= row.id %>"><%= row.genre %></label>
          </div>
         <% }) %>
         </div>
        <div class="view-button-container">
          <a href="/games/">Go Back</a>
          <button type="submit">Submit New Game</button>
        </div>
      </form>
    </main>
    <%- include("../partials/footer") %>
  </body>
</html>
