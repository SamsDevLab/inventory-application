<!-- Edit Game View -->
<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head") %>
  <body>
    <%- include("../partials/header") %>
    <main>
      <form class="game-form" action="/games/edit/1" method="POST">
        <div class="game-title-container">
          <label for="game">Game Title</label>
          <input
            type="text"
            name="<%= gameData.gameTitle[0].id %>"
            id="game"
            value="<%= gameData.gameTitle[0].game %>"
            required
          />
        </div>
        <h3>Developer (select as many as needed)</h3>
        <div class="selection-container">
          <% gameData.allDevelopers.forEach(developer => { %>
            <div>
              <input type="checkbox" id="checkbox" name="<%= developer.id %>" 
                <% gameData.gameDevelopers.forEach(gameDev => { %>
                  <% if (gameDev.id === developer.id) { %>
                      checked
                <% } %>
              <% }) %> />
              <label for="checkbox"><%= developer.developer %></label>
            </div>
          <% }) %>
        </div>
        <h3>Genre (select as many as needed)</h3>
        <div class="selection-container">
         <% gameData.allGenres.forEach(genre => { %>
            <div>
              <input type="checkbox" id="checkbox" name="<%= genre.id %>" 
                <% gameData.gameGenres.forEach(gameGenre => { %>
                  <% if (gameGenre.id === genre.id) { %>
                      checked
                  <% } %>
                <% }) %> />
              <label for="checkbox"><%= genre.genre %></label>
            </div>
          <% }) %>
        </div>
        <div class="view-button-container">
          <a href="/games/">Go Back</a>
          <button type="submit">Save Edits</button>
        </div>
      </form>
    </main>
    <%- include("../partials/footer") %>
  </body>
</html>
