<!-- Edit Game View -->
<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head") %>
  <body>
    <%- include("../partials/header") %>
    <main>
      <form class="game-form" action="/games/edit/1" method="POST">
        <div class="game-title-container">
          <label for="game">Game Title</label>
          <input type="text" name="game" id="game" required />
        </div>
        <h3>Developer (select as many as needed)</h3>
        <div class="selection-container">
          <% developers.forEach(dev => { %>
            <div>
              <input type="checkbox" id="<%= dev.developer %>" name="<%= dev.id %>" />
              <label for="<%= dev.developer %>"><%= dev.developer %></label>
            </div>
          <% })%> 
        </div>
        <h3>Genre (select as many as needed)</h3>
        <div class="selection-container">
          <% genres.forEach(genre => { %>
            <div>
              <input type="checkbox" id="<%= genre.genre %>" name="<%= genre.id %>" />
              <label for="<%= genre.genre %>"><%= genre.genre %></label>
            </div>
          <% }) %>
        </div>
        <div class="view-button-container">
          <a href="/games/">Go Back</a>
          <button type="submit">Save Edits</button>
        </div>
      </form>
    </main>
    <%- include("../partials/footer") %>
  </body>
</html>
