<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head") %>
  <body>
    <%- include("../partials/header") %>
    <main>
      <form
        class="add-and-edit-form add-and-edit-genre"
        action="/genres/edit/<%= genre.id %>"
        method="POST"
      >
        <div class="title-container">
          <label for="<%= genre.id %>">Edit Genre</label>
          <input
            type="text"
            name="genre"
            id="<%= genre.id %>"
            value="<%= genre.genre %>"
            required
          />
        </div>
        <div class="view-button-container">
          <a href="/genres/">Back</a>
          <button type="text">Submit</button>
        </div>
      </form>
    </main>
    <%- include("../partials/footer") %>
  </body>
</html>
